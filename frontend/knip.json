{
    "entry": ["src/main.tsx", "src/i18n.ts"],
    "project": ["src/**/*.{ts,tsx}"],
    "ignore": [
        "src/**/*.test.{ts,tsx}",
        "src/test/**",
        "src/hooks/useFineSortDrag.ts",
        "src/contexts/LayoutContext.context.ts",
        "src/schemas/study.ts",
        "src/api/generated.ts",
        "src/api/model/**",
        "src/components/ui/**"
    ],
    "ignoreBinaries": ["jscpd", "python3"],
    "ignoreDependencies": [
        "@fontsource/google-sans-flex",
        "autoprefixer",
        "postcss",
        "tailwindcss",
        "@dnd-kit/modifiers",
        "clsx",
        "tailwind-merge",
        "@testing-library/dom",
        "@vitest/coverage-v8",
        "eslint-config-prettier",
        "eslint-plugin-prettier",
        "@radix-ui/react-accordion",
        "@radix-ui/react-collapsible",
        "next-themes",
        "recharts",
        "vaul"
    ]
}
